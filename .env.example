PRIVY_APP_ID=your_app_id_here
PRIVY_CLIENT_ID=your_client_id_here
PRIVY_OAUTH_APP_URL_SCHEME=your.app.scheme

# Set to 'true' to enable gas sponsorship for Privy embedded wallet transactions.
GAS_SPONSORSHIP=false

# Reown AppKit Project ID for external wallet signing
REOWN_PROJECT_ID=your_reown_project_id_here

# Infura RPC token used to build RPC URL
INFURA_TOKEN=your_infura_token_here